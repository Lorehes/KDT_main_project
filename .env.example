# =============================================================
# DartCommons — 환경변수 템플릿 (커밋 허용, 단일 .env 규약)
# 실제 값은 .env 에 작성 (gitignore됨). cp .env.example .env → 값 채우기.
# 런타임 파일은 .env 하나 — docker-compose.yml 이 env_file + ${}보간에 모두 사용.
#
# [필수 5종] 기본값 없음: DART_API_KEY, KRX_API_KEY, JWT_SECRET, AES_KEY, ADMIN_PASSWORD
# 아래 값들은 로컬 개발 기본값. ★서버 배포 시 [서버 배포] 섹션 참고해 교체★.
# =============================================================

# =============================================================
# [서버 배포 — Lightsail 단독, docker-compose.yml] 전용 변수
#   서버에서 바꿔야 할 것: DB_URL(→postgres:5432), DOMAIN, DARTCOMMONS_ALLOWED_ORIGINS(→도메인),
#     SPRING_PROFILES_ACTIVE=prod, KAKAO_REDIRECT_URI(→https 도메인), LLM(운영 공급자).
#   로컬 개발이면 이 섹션은 무시(compose 미사용) 가능.
# =============================================================
# 도메인 / SSL (certbot)
DOMAIN=your-domain.com
CERTBOT_EMAIL=CHANGE_ME_your-email@example.com
CERTBOT_STAGING=0                 # 1=스테이징 리허설 / 0=실발급
CERTBOT_CONF_DIR=/home/ubuntu/data/certbot/conf
CERTBOT_WWW_DIR=/home/ubuntu/data/certbot/www
# 이미지 태그 (build: 로 서버 직접 빌드 / ECR·GHCR pull 시 레지스트리 URL로 교체)
BACKEND_IMAGE=dartcommons-backend:latest
FRONTEND_IMAGE=dartcommons-frontend:latest
# FE 빌드 타임 주입 (도메인 변경 시 재빌드)
NEXT_PUBLIC_API_URL=https://your-domain.com
# 프로파일 / CORS (서버)
# SPRING_PROFILES_ACTIVE=prod
# SWAGGER_ENABLED=false
# DARTCOMMONS_ALLOWED_ORIGINS=https://your-domain.com
# =============================================================

# ----- Database -----
# 로컬: localhost:5433 (docker-compose 로컬 dev) / 서버: postgres:5432 (컨테이너 네트워크)
DB_URL=jdbc:postgresql://localhost:5433/dartcommons
DB_NAME=dartcommons
DB_USERNAME=dartcommons
DB_PASSWORD=dartcommons
# Postgres bind mount 위치 — Docker reset/clean 영향 받지 않는 호스트 디렉토리.
# 미설정 시 ~/data/dartcommons-pg 기본값(docker-compose.yml). 변경 권고 X
# 자세한 내용: docs/개발명세서/data_protection.md
# PG_DATA_DIR=${HOME}/data/dartcommons-pg

# ----- Server -----
SERVER_PORT=8080

# ----- DART OpenAPI -----
DART_API_KEY=

# ----- KRX OpenAPI -----
KRX_API_KEY=

# ----- /admin/** HTTP Basic (MVP — JWT 도입 전 단순 가드) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----- JWT -----
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ----- Kakao 알림톡 -----
# 변수명은 application.yml(dartcommons.kakao.alimtalk.*)과 정합. 미설정 시 placeholder → dev 모드(실 API 미호출).
# 운영 발송은 카카오 비즈채널 승인 + 템플릿 심사 후 sender-key/template-code 발급값 주입(kakao-notification-channel Wave 3).
KAKAO_ALIMTALK_BASE_URL=https://alimtalk-api.kakao.com
KAKAO_ALIMTALK_API_KEY=
KAKAO_SENDER_KEY=
KAKAO_ALIMTALK_TEMPLATE_CODE=
KAKAO_OTP_TEMPLATE_CODE=dc_otp_v1

# ----- 텔레그램 알림 (전 티어 무료 — telegram-notification-channel Spec) -----
# BotFather에서 봇 생성 후 토큰 주입. 미설정 시 placeholder → dev 모드(실 API 미호출).
# 폴링(getUpdates) 방식이므로 봇에 webhook 설정 금지. 토큰 유출 시 BotFather /revoke 재발급.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ----- Email (알림 폴백 채널 — MailNotificationClient) -----
# 미설정 시 application.yml 기본값(localhost:1025 = MailHog) 사용 → 부팅 실패 없음.
# 로컬 SMTP 모킹: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog (웹 UI :8025).
# Gmail 실발송 테스트: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_SMTP_AUTH=true, MAIL_SMTP_STARTTLS=true, App Password 사용.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=noreply@dartcommons.com

# ----- 텔레그램 (폴백) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- LLM (analysis Stage 2~5, LangChain4j) -----
# provider: mock | ollama. wave 1은 mock(통합 테스트 + 로컬 검증), wave 2 후 ollama 전환.
LLM_PROVIDER=mock
# MVP Ollama Local — Spec 결정 4(wave 2 smoke test 확정): qwen3:4b
# 비교 근거: docs/dev-log/analysis-stage2-smoke.md (gemma3:4b는 유상증자 → POSITIVE 오분류 위험)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:4b
# provider=ollama 필수 — application.yml llm.base-url 기본값은 openrouter.ai(프로덕션).
# 미설정 시 OllamaLlmClient가 openrouter로 /api/generate 호출 → 404, 분석 전건 실패.
# (OLLAMA_BASE_URL은 이 클라이언트가 안 씀 — 반드시 LLM_BASE_URL 사용)
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
# 결정 2: 0.6 미만 → is_withheld=true (판단 보류). 운영 조정은 SystemConfig 키 검토.
LLM_CONFIDENCE_THRESHOLD=0.6

# ----- Stage 3 RAG (Chroma 벡터 DB + Ollama 임베딩) -----
# 로컬 활성화: CHROMA_ENABLED=true + EMBEDDING_PROVIDER=ollama
# 사전 조건: ollama pull nomic-embed-text && docker compose up -d chroma
# Chroma bind mount 위치 — 미설정 시 ~/data/dartcommons-chroma (docker-compose.yml 기본값)
# ★서버(컨테이너 스택) 값 — 컨테이너 간 통신은 서비스명 사용 (운영가이드 §9):
#   CHROMA_ENABLED=true / CHROMA_BASE_URL=http://chroma:8000
#   EMBEDDING_PROVIDER=ollama / EMBEDDING_BASE_URL=http://ollama:11434
#   모델 pull 1회: docker exec dartcommons-ollama ollama pull nomic-embed-text
CHROMA_ENABLED=false
CHROMA_BASE_URL=http://localhost:8001
CHROMA_COLLECTION=disclosure_embeddings
CHROMA_SIMILARITY_THRESHOLD=0.7
CHROMA_TIMEOUT_MS=10000
# CHROMA_DATA_DIR=${HOME}/data/dartcommons-chroma

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_MAX_RETRIES=2
EMBEDDING_MAX_CHARS=6000

# ----- Frontend -----
# Next.js 변수는 frontend/.env.example 참고

# =============================================================
# DartCommons — 환경변수 템플릿 (커밋 허용)
# 실제 값은 .env 에 작성 (gitignore됨)
# =============================================================

# ----- Database -----
# 호스트 포트 5433 — docker-compose.yml과 정합 (다른 프로젝트 5432 점유 회피)
DB_URL=jdbc:postgresql://localhost:5433/dartcommons
DB_USERNAME=dartcommons
DB_PASSWORD=dartcommons
# Postgres bind mount 위치 — Docker reset/clean 영향 받지 않는 호스트 디렉토리.
# 미설정 시 ~/data/dartcommons-pg 기본값(docker-compose.yml). 변경 권고 X
# 자세한 내용: docs/개발명세서/data_protection.md
# PG_DATA_DIR=${HOME}/data/dartcommons-pg

# ----- Server -----
SERVER_PORT=8080

# ----- DART OpenAPI -----
DART_API_KEY=

# ----- KRX OpenAPI -----
KRX_API_KEY=

# ----- /admin/** HTTP Basic (MVP — JWT 도입 전 단순 가드) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----- JWT -----
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ----- Kakao 알림톡 -----
# 변수명은 application.yml(dartcommons.kakao.alimtalk.*)과 정합. 미설정 시 placeholder → dev 모드(실 API 미호출).
# 운영 발송은 카카오 비즈채널 승인 + 템플릿 심사 후 sender-key/template-code 발급값 주입(kakao-notification-channel Wave 3).
KAKAO_ALIMTALK_BASE_URL=https://alimtalk-api.kakao.com
KAKAO_ALIMTALK_API_KEY=
KAKAO_SENDER_KEY=
KAKAO_ALIMTALK_TEMPLATE_CODE=
KAKAO_OTP_TEMPLATE_CODE=dc_otp_v1

# ----- Email (알림 폴백 채널 — MailNotificationClient) -----
# 미설정 시 application.yml 기본값(localhost:1025 = MailHog) 사용 → 부팅 실패 없음.
# 로컬 SMTP 모킹: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog (웹 UI :8025).
# Gmail 실발송 테스트: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_SMTP_AUTH=true, MAIL_SMTP_STARTTLS=true, App Password 사용.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=noreply@dartcommons.com

# ----- 텔레그램 (폴백) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- LLM (analysis Stage 2~5, LangChain4j) -----
# provider: mock | ollama. wave 1은 mock(통합 테스트 + 로컬 검증), wave 2 후 ollama 전환.
LLM_PROVIDER=mock
# MVP Ollama Local — Spec 결정 4(wave 2 smoke test 확정): qwen3:4b
# 비교 근거: docs/dev-log/analysis-stage2-smoke.md (gemma3:4b는 유상증자 → POSITIVE 오분류 위험)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:4b
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
# 결정 2: 0.6 미만 → is_withheld=true (판단 보류). 운영 조정은 SystemConfig 키 검토.
LLM_CONFIDENCE_THRESHOLD=0.6

# ----- Stage 3 RAG (Chroma 벡터 DB + Ollama 임베딩) -----
# 로컬 활성화: CHROMA_ENABLED=true + EMBEDDING_PROVIDER=ollama
# 사전 조건: ollama pull nomic-embed-text && docker compose up -d chroma
# Chroma bind mount 위치 — 미설정 시 ~/data/dartcommons-chroma (docker-compose.yml 기본값)
CHROMA_ENABLED=false
CHROMA_BASE_URL=http://localhost:8001
CHROMA_COLLECTION=disclosure_embeddings
CHROMA_SIMILARITY_THRESHOLD=0.7
CHROMA_TIMEOUT_MS=10000
# CHROMA_DATA_DIR=${HOME}/data/dartcommons-chroma

EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_MAX_RETRIES=2
EMBEDDING_MAX_CHARS=6000

# ----- Frontend -----
# Next.js 변수는 frontend/.env.example 참고

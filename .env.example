# =============================================================
# DartCommons — 환경변수 템플릿 (커밋 허용)
# 실제 값은 .env 에 작성 (gitignore됨)
# =============================================================

# ----- Database -----
# 호스트 포트 5433 — docker-compose.yml과 정합 (다른 프로젝트 5432 점유 회피)
DB_URL=jdbc:postgresql://localhost:5433/dartcommons
DB_USERNAME=dartcommons
DB_PASSWORD=dartcommons

# ----- Server -----
SERVER_PORT=8080

# ----- DART OpenAPI -----
DART_API_KEY=

# ----- KRX OpenAPI -----
KRX_API_KEY=

# ----- /admin/** HTTP Basic (MVP — JWT 도입 전 단순 가드) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----- JWT -----
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ----- Kakao 알림톡 -----
KAKAO_ALIMTALK_APP_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

# ----- 텔레그램 (폴백) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- LLM (MVP: Ollama) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ----- Frontend -----
# Next.js 변수는 frontend/.env.example 참고

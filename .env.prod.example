# =============================================================================
# DartCommons 프로덕션 환경변수 템플릿
# 사용법: cp .env.prod.example .env.prod  → 실제 값 채우기 → 서버 직접 생성
# 주의: .env.prod 는 git 커밋 금지 (CLAUDE.md §7). 이 파일(.example)만 커밋.
# =============================================================================

# ----- Docker 이미지 (GHCR) -----
# GitHub 사용자명 또는 조직명 (소문자)
# 예: GITHUB_REPOSITORY_OWNER=dartcommons-team
GITHUB_REPOSITORY_OWNER=your-github-username

# ----- PostgreSQL -----
DB_URL=jdbc:postgresql://postgres:5432/dartcommons
DB_NAME=dartcommons
DB_USERNAME=dartcommons
DB_PASSWORD=CHANGE_ME_strong_password

# PostgreSQL bind mount 경로 (EC2 기본값 사용 시 주석 유지)
# PG_DATA_DIR=/home/ubuntu/data/dartcommons-pg

# ----- JWT -----
# 최소 32자 이상 랜덤 문자열 권장: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_jwt_secret_min_32chars
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# ----- AES-256-GCM (매수가·보유량·전화번호 암호화) -----
# 정확히 32바이트 Base64: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
AES_KEY=CHANGE_ME_32byte_base64_encoded_key

# ----- DART OpenAPI -----
DART_API_KEY=CHANGE_ME_dart_api_key

# ----- KRX OpenAPI -----
KRX_API_KEY=CHANGE_ME_krx_api_key
KRX_BASE_URL=https://data.krx.co.kr

# ----- LLM (llm-production-switch Spec 커밋 08af22b) -----
# OpenRouter(Cloud): LLM_PROVIDER=openrouter (t3.medium 4GB 가능)
# Ollama(온프레미스): LLM_PROVIDER=ollama (t3.large 8GB 이상 필요)
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-3-4b-it:free
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2
LLM_CONFIDENCE_THRESHOLD=0.6
# OpenRouter 사용 시 필수 (provider=openrouter)
OPENROUTER_API_KEY=CHANGE_ME_openrouter_api_key

# ----- 메일 (알림 폴백 채널) -----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_email@gmail.com
MAIL_PASSWORD=CHANGE_ME_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=noreply@dartcommons.com

# ----- 카카오 알림톡 -----
KAKAO_ALIMTALK_BASE_URL=https://alimtalk-api.kakao.com
KAKAO_ALIMTALK_API_KEY=CHANGE_ME_kakao_alimtalk_key
KAKAO_SENDER_KEY=CHANGE_ME_kakao_sender_key
KAKAO_ALIMTALK_TEMPLATE_CODE=CHANGE_ME_template_code
KAKAO_OTP_TEMPLATE_CODE=dc_otp_v1

# ----- 카카오 OAuth -----
KAKAO_CLIENT_ID=CHANGE_ME_kakao_client_id
KAKAO_CLIENT_SECRET=CHANGE_ME_kakao_client_secret
KAKAO_REDIRECT_URI=https://your-domain.com/auth/oauth/kakao/callback

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=CHANGE_ME_google_client_id
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/oauth/google/callback

# ----- Naver OAuth -----
NAVER_CLIENT_ID=CHANGE_ME_naver_client_id
NAVER_CLIENT_SECRET=CHANGE_ME_naver_client_secret
NAVER_REDIRECT_URI=https://your-domain.com/auth/oauth/naver/callback

# ----- 어드민 HTTP Basic -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ----- 서버 설정 -----
SERVER_PORT=8080
# prod 프로파일 활성화 → Swagger UI 비활성화
SPRING_PROFILES_ACTIVE=prod

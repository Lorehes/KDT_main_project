# dc-review-frontend --auth login 모드 자격증명
# 이 파일을 .env.review로 복사해 실제 값으로 채우세요.
# ⚠️ .env.review는 .gitignore에 의해 추적 제외됨 (절대 커밋하지 마세요)

# 테스트 계정 (onboarding_completed=true 계정 필수)
REVIEW_AUTH_EMAIL=test@example.com
REVIEW_AUTH_PASSWORD=your_password_here

# BE URL (기본값: http://localhost:8080/api/v1)
# REVIEW_BE_URL=http://localhost:8080/api/v1
